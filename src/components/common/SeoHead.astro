---
/**
 * Centralized <head> SEO tags shared by all layouts.
 * Render inside each layout's <head>: <SeoHead title={...} description={...} ... />
 *
 * Owns: charset/viewport/title, GTM, meta description, canonical, theme-color,
 * Open Graph, Twitter cards, robots, JSON-LD, favicon, and fonts — so these stay
 * consistent across Layout / BaseLayout / BlogLayout / LandingLayout.
 */
import GoogleTagManager from '@/components/common/GoogleTagManager.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://oasishealthservices.com';
const SITE_NAME = 'Oasis Health Services';
const DEFAULT_IMAGE = '/images/home/home-banner-1.webp';

interface Props {
    title?: string;
    description?: string;
    keywords?: string;
    image?: string;
    type?: 'website' | 'article';
    noindex?: boolean;
    schema?: object;
}

const {
    title = 'Virtual Mental Health Care',
    description = 'Expert mental health care tailored for you, combining psychiatric and primary care for whole-person healing. Covered by insurance.',
    keywords,
    image,
    type = 'website',
    noindex = false,
    schema,
} = Astro.props;

// Format title (max 60 chars for SEO)
const formattedTitle = title.length > 60 ? title.substring(0, 57) + '...' : title;
const pageTitle = `${formattedTitle} | ${SITE_NAME}`;

// Format description (max 155 chars for SEO)
const formattedDescription = description.length > 155
    ? description.substring(0, 152) + '...'
    : description;

// Build full URLs
const currentPath = Astro.url.pathname;
const fullUrl = `${SITE_URL}${currentPath}`;
const ogImage = image
    ? (image.startsWith('http') ? image : `${SITE_URL}${image}`)
    : DEFAULT_IMAGE;

// Never let the staging site be indexed (belt-and-suspenders alongside its
// basic-auth and robots.txt Disallow).
const blockIndexing = noindex || import.meta.env.STAGING === true;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{pageTitle}</title>

<GoogleTagManager part="head" />

<!-- Basic Meta Tags -->
<meta name="description" content={formattedDescription} />
{keywords && <meta name="keywords" content={keywords} />}
<link rel="canonical" href={fullUrl} />
<meta name="theme-color" content="#2D6762">

<!-- Open Graph / Facebook -->
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={formattedDescription} />
<meta property="og:type" content={type} />
<meta property="og:url" content={fullUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={formattedTitle} />

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={fullUrl} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={formattedDescription} />
<meta name="twitter:image" content={ogImage} />

<!-- Robots -->
{blockIndexing ? (
    <meta name="robots" content="noindex,nofollow" />
) : (
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
)}

<!-- RSS feed autodiscovery -->
<link rel="alternate" type="application/rss+xml" title="Oasis Health Services Blog" href="/rss.xml" />

<!-- Schema.org JSON-LD -->
{schema && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
)}

<!-- Favicon -->
<link rel="icon" type="image/png" sizes="32x32" href="/images/oasis-favicon.png">
<link rel="icon" type="image/png" sizes="16x16" href="/images/oasis-favicon.png">
<link rel="apple-touch-icon" sizes="180x180" href="/images/oasis-favicon.png">

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&family=Source+Sans+Pro:wght@400;600;700&display=swap" rel="stylesheet">
