---
import '../styles/global.css';
import GoogleTagManager from '@/components/common/GoogleTagManager.astro';
import SeoHead from '@/components/common/SeoHead.astro';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	image?: string;
	type?: 'website' | 'article';
	noindex?: boolean;
	schema?: object;
}

const {
	title = "Oasis Support & Resource Center",
	description = "A supportive mental health resource center: understanding feelings, getting help, building skills, and supporting the people you love.",
	keywords,
	image,
	type = 'website',
	noindex = false,
	schema
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<SeoHead title={title} description={description} keywords={keywords} image={image} type={type} noindex={noindex} schema={schema} />
	</head>
	<body class="bg-white text-foreground font-sans">
		<GoogleTagManager part="body" />

		<div class="min-h-screen flex flex-col">
			<main class="flex-grow">
				<slot />
			</main>
		</div>
	</body>
</html>
