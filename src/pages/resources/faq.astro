---
import Layout from '../../layouts/Layout.astro';
import FAQPage, { faqData } from '@/components/pages/resources/FAQ';
import { getOrganizationSchema, getFaqSchema } from '@/utils/schema';

const allFaqs = Object.values(faqData).flat();
const schema = [getOrganizationSchema(), getFaqSchema(allFaqs)];
---

<Layout
  title="FAQ Resources"
  description="FAQ Resources for mental health care and psychiatric services."
  schema={schema}
>
  <FAQPage client:load /> 
</Layout>
