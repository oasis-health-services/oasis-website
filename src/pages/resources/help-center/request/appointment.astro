---
import Layout from '@/layouts/Layout.astro';
import { getOrganizationSchema } from '@/utils/schema';
import HelpdeskRequest from '@/components/pages/resources/help-center/request/HelpdeskRequest';
import type { HelpdeskInquiryType } from '@/lib/schema';

const config = {
    id: "appointment",
    title: "Appointment Help",
    inquiryType: "appointment_request" as HelpdeskInquiryType,
    description: "Reschedule, cancel, or request new appointment availability.",
    icon: "CalendarClock",
    subjectPlaceholder: "e.g., Need to reschedule my March 15 appointment",
    messagePlaceholder: "Please include:\n- Your current appointment date (if rescheduling)\n- Preferred new dates/times\n- Your provider's name\n- Reason for change (optional)",
    apiEndpoint: "/api/help-center",
    thankYouType: "helpdesk",
    response: { time: "1-2 business days", note: "Most questions are answered within 24 hours." }
  };
---

<Layout 
  title="Appointment Help | Help Center"
  description="Reschedule, cancel, or request new appointment availability at Oasis Health Services."
  keywords="help center, appointments, Oasis Health Services, Roswell"
  schema={getOrganizationSchema()}
>

    <HelpdeskRequest.HeroSection config={config} client:load />
    <HelpdeskRequest.MainSection config={config} client:visible />

</Layout>
